# Copy values into your MCP client's env configuration.
# Do not commit a real .env file.

# Recommended for most users: organization API key.
LC_API_KEY=your-organization-api-key

# Optional. Use only for user API key mode. Keep separate from LC_API_KEY.
# LC_UID=your-user-id
# LC_USER_API_KEY=your-user-api-key
# LC_AUTH_MODE=user_api_key

# Optional service overrides for testing or private deployments.
# LC_API_ROOT=https://api.limacharlie.io
# LC_JWT_ROOT=https://jwt.limacharlie.io
# LC_CASES_API_ROOT=https://cases.limacharlie.io
# LC_MCP_TIMEOUT_SECONDS=30
# LC_MCP_AUDIT_LOG=/path/to/audit.jsonl

# Optional profile when running the generic limacharlie-mcp command.
# Prefer profile-specific commands such as limacharlie-mcp-review in MCP clients.
# LC_MCP_PROFILE=review
